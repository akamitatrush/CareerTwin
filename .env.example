# Supabase (obrigatório para auth, banco e storage)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# NUNCA use a service_role no cliente ou no código do app.
# SUPABASE_SERVICE_ROLE_KEY=  # não configurar no frontend

# URL pública do app (usada em redirects de auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# IA: "mock" | "xai" (Grok) | "grok" | "openai"
AI_PROVIDER=mock

# --- Grok / xAI (recomendado para este projeto) ---
# Crie a chave em https://console.x.ai/
XAI_API_KEY=
# Modelos comuns: grok-3-mini | grok-3 | grok-2-latest
XAI_MODEL=grok-3-mini
# XAI_BASE_URL=https://api.x.ai/v1

# --- OpenAI (alternativa) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
